    "Apply a Thaw menu bar profile when this Focus activates." : {
      "comment" : "Description of the \"Set Menu Bar Profile\" focus filter intent, including the category name.",
      "localizations" : {
        "cs" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Po aktivaci tohoto režimu soustředění přepne Thaw svůj profil."
          }
        },
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Ein Thaw-Menüleisten-Profil anwenden, wenn dieser Fokus aktiviert wird."
          }
        },
        "es" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Aplicar un perfil de barra de menú de Thaw cuando este Enfoque se activa."
          }
        },
        "fr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Appliquer un profil de la barre de menu de Thaw lorsque le focus est activé."
          }
        },
        "hu" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Thaw menüsávprofil alkalmazása, amikor ez a Fókusz aktiválódik."
          }
        },
        "id" : {
          "stringUnit" : {
            "state" : "translated",

            "value" : "Bestehende Einstellungen importieren?"
          }
        },
        "es" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "¿Deseas importar tu configuración existente?"
          }
        },
        "fr" : {
          "stringUnit" : {
            "state" : "translated",

    "Double-click %@ icon to open always-hidden section" : {
      "comment" : "A toggle that lets the user enable or disable the option of using double-clicking the app icon to open the always-hidden section.",
      "localizations" : {
        "cs" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Otevřít sekci „Trvale skryté“ dvojitým poklepáním na ikonu %@"
          }
        },
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "%@-Symbol doppelklicken, um den Immer-Versteckt-Bereich anzuzeigen"
          }
        },
        "es" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Haz doble clic en el icono %@ para abrir la sección que siempre está oculta"
          }
        },
        "fr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Double-cliquez sur l'icône %@ pour ouvrir la section cachée"
          }
        },
        "hu" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Kattints duplán a %@ ikonra a mindig rejtett szakasz megnyitásához"
          }
        },
        "id" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Klik dua kali ikon %@ untuk membuka bagian selalu-tersembunyi"
          }
        },
        "it" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Doppio click sull'icona %@ per aprire la sezione sempre nascosto"
          }
        },
        "ja" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "%@ アイコンをダブルクリックして常に非表示セクションを開く"
          }
        },
        "ko" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "%@ 아이콘을 더블 클릭하여 항상 숨김 섹션을 열기"
          }
        },
        "nl" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Dubbelklik op het %@-pictogram om het altijd verborgen gedeelte te openen"
          }
        },
        "pl" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Kliknij dwukrotnie ikonę %@, aby otworzyć zawsze ukrytą sekcję"
          }
        },
        "pt-BR" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Duplo clique no ícone %@ para abrir a seção Sempre Ocultos"
          }
        },
        "ru" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Дважды щелкните значок %@, чтобы открыть скрытый раздел"
          }
        },
        "th" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "ดับเบิลคลิกไอคอน %@ เพื่อเปิดส่วนที่ถูกซ่อนตลอดเวลา"
          }
        },
        "tr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Her zaman gizli bölümünü açmak için %@ ikonunu iki kez tıkla"
          }
        },
        "uk" : {
          "stringUnit" : {
            "state" : "new",
            "value" : "Double-click %@ icon to open always-hidden section"
          }
        },
        "vi" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Bấm đúp vào biểu tượng %@ để mở phần luôn bị ẩn"
          }
        },
        "zh-Hans" : {
          "stringUnit" : {

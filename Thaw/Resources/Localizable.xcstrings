        },
        "vi" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Bấm đúp vào vùng trống của thanh menu để hiển thị các mục thanh menu luôn bị ẩn."
          }
        },
        "zh-Hans" : {
          "stringUnit" : {

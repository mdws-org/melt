        }
      }
    },
    "Apply briefly relaunches apps with menu bar items so they pick up the new spacing. Setting takes effect when this display is the active menu bar display." : {
      "comment" : "Tooltip for the spacing row in the display settings pane.",
      "localizations" : {
        "cs" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Po použití se krátce restartují aplikace s položkami v řádku nabídek, tím se nové rozestupy aktivují. Změny se projeví, až se tento monitor stane aktivní obrazovkou lišty nabídek."
          }
        },
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "„Anwenden“ startet Apps mit Menüleistensymbolen kurzzeitig neu, damit diese die neuen Abstände übernehmen. Die Einstellung wird wirksam, wenn dieses Display die aktive Anzeige für die Menüleiste ist."
          }
        },
        "es" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Al aplicar, se reinician las aplicaciones con elementos en la barra de menús para que adopten el nuevo espaciado. El ajuste se aplica cuando esta es la vista activa de la barra de menús."
          }
        },
        "fr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "\"Appliquer\" redémarre les applications comportant des éléments dans la barre de menus afin qu'elles prennent en compte le nouvel espacement. Ce paramètre s'applique lorsque cet écran est l'affichage actif de la barre de menus."
          }
        },
        "hu" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Az „Alkalmazás” rövid időre újraindítja a menüsávelemekkel rendelkező alkalmazásokat, hogy átvegyék az új térközt. A beállítás akkor lép érvénybe, amikor ez a kijelző az aktív menüsáv kijelzője."
          }
        },
        "id" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Terapkan akan memulai ulang aplikasi dengan item bar menu secara singkat agar menerapkan jarak baru. Pengaturan ini berlaku saat layar ini menjadi layar bar menu aktif."
          }
        },
        "it" : {
          "stringUnit" : {
            "state" : "new",
            "value" : "Apply briefly relaunches apps with menu bar items so they pick up the new spacing. Setting takes effect when this display is the active menu bar display."
          }
        },
        "ja" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "「適用」をクリックすると、メニューバー項目を含むアプリが一時的に再起動され、新しい間隔が反映されます。この設定はアクティブなメニューバーディスプレイでのみ有効です。"
          }
        },
        "ko" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "적용 시 새로운 간격을 반영하기 위해 메뉴 막대 항목이 있는 앱을 잠시 재실행합니다. 이 설정은 해당 디스플레이가 활성 메뉴 막대 디스플레이일 때 적용됩니다."
          }
        },
        "nl" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Als je ‘Toepassen’ selecteert, worden apps met menu-items kort opnieuw gestart, zodat de nieuwe spatiëring wordt toegepast. De instelling wordt van kracht zodra dit venster het actieve menubalkvenster is."
          }
        },
        "pl" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Kliknięcie \"Zastosuj\" zrestartuje na chwilę aplikacje paska menu, aby zaktualizować odstępy. Opcja ta działa tylko wtedy, gdy ten monitor wyświetla aktywny pasek menu."
          }
        },
        "pt-BR" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "A opção “Aplicar” reinicia rapidamente os aplicativos com itens na barra de menus para que eles adotem o novo espaçamento. A configuração entra em vigor quando esta exibição for a exibição ativa da barra de menus."
          }
        },
        "ru" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "\"Применить\" кратковременно перезапускает приложения с элементами в строке меню, чтобы в них были применены новые интервалы. Настройка вступает в силу, когда этот вид отображения является активным в строке меню."
          }
        },
        "th" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "การนำไปใช้จะรีสตาร์ทแอปที่มีรายการในแถบเมนูชั่วคราว เพื่อให้แอปเหล่านั้นใช้ระยะห่างใหม่ การตั้งค่านี้จะมีผลเมื่อจอแสดงผลนี้เป็นจอที่ใช้แถบเมนูหลักอยู่"
          }
        },
        "tr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Uygula seçeneği yeni aralığı algılayabilmeleri için menü çubuğu ögelerine sahip uygulamaları kısa süreliğine yeniden başlatır. Seçilen ayar, kullanılan ekran aktif menü çubuğu ekranı olduğunda geçerli olur."
          }
        },
        "uk" : {
          "stringUnit" : {
            "state" : "new",
            "value" : "Apply briefly relaunches apps with menu bar items so they pick up the new spacing. Setting takes effect when this display is the active menu bar display."
          }
        },
        "vi" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Áp dụng sẽ khởi chạy lại nhanh các ứng dụng có các mục trên thanh menu để chúng có khoảng cách mới. Cài đặt có hiệu lực khi màn hình này là màn hình thanh menu hoạt động."
          }
        },
        "zh-Hans" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "应用设置后将短暂重启带有菜单栏图标的 App，以使其采用新的间距。此设置仅在此显示器作为当前活跃的菜单栏显示器时生效。"
          }
        },
        "zh-Hant" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "「套用」會短暫重新啟動具有選單列項目的應用程式，使其採用新間距。此設定僅在此顯示器為目前選單列顯示器時生效。"
          }
        }
      }
    },
    "Apply different settings based on the current system appearance." : {
      "comment" : "Label for a toggle that allows the user to choose whether to use different appearance settings based on the current system appearance.",
      "localizations" : {
        "cs" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Použít různé nastavení v závislosti na aktuálním vzhledu systému."
          }
        },
        "de" : {
          "stringUnit" : {
            "state" : "translated",

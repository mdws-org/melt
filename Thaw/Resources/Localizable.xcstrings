        }
      }
    },
    "Always show the %@ Bar at the mouse pointer's location when it is shown using a hotkey." : {
      "comment" : "A toggle that lets users decide whether the location of the \\(Constants.displayName) Bar should be fixed at the mouse pointer's location when it is shown using a hotkey.",

          }
        },
        "ja" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "集中モード有効時に、指定した Thaw メニューバープロファイルを適用します。"
          }
        },
        "ko" : {
          "stringUnit" : {
            "state" : "translated",

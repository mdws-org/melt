    "Layout reset. Items were moved to the Hidden section." : {
      "comment" : "A message displayed after successfully resetting the menu bar layout.",
      "localizations" : {
        "cs" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Obnovení rozložení. Položky byly přesunuty do sekce „Skryté“."
          }
        },
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Darstellung zurücksetzen. Einträge wurden in den verstecken Bereich verschoben."
          }
        },
        "es" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Se restableció la disposición. Los elementos se movieron a la sección Ocultos."
          }
        },
        "fr" : {
          "stringUnit" : {
            "state" : "translated",

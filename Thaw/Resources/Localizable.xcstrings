    "No profiles saved yet. Create one in the Profiles tab to attach per-profile hooks." : {
      "comment" : "A message displayed when there are no profiles saved yet.",
      "localizations" : {
        "cs" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Nejsou uložené žádné profily. Když je vytvoříte v sekci Profily, můžete je zde přiřadit."
          }
        },
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Bisher kein Profil gespeichert. Ein Profil im Bereiche Profile erstellen um Hooks anzuhängen."
          }
        },
        "es" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Aún no hay perfiles guardados. Crea uno en la pestaña Perfiles para añadir ganchos específicos para cada perfil."
          }
        },
        "fr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Aucun profil n’a encore été enregistré. Créez-en un dans l’onglet Profils pour y associer des hooks par profil."
          }
        },
        "hu" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Még nincsenek mentett profilok. Hozz létre egyet a Profilok lapon, hogy profilhoz kötött hookokat rendelhess hozzá."
          }
        },
        "id" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Belum ada profil yang tersimpan. Buat di tab Profil untuk memasang hook per profil."
          }
        },
        "it" : {
          "stringUnit" : {
            "state" : "new",
            "value" : "No profiles saved yet. Create one in the Profiles tab to attach per-profile hooks."
          }
        },
        "ja" : {
          "stringUnit" : {
            "state" : "new",
            "value" : "No profiles saved yet. Create one in the Profiles tab to attach per-profile hooks."
          }
        },
        "ko" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "저장된 프로필이 없습니다. '프로필' 탭에서 새로 만들고 프로필별 훅을 설정하세요."
          }
        },
        "nl" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Er zijn nog geen profielen opgeslagen. Maak er een aan op het tabblad Profielen om hooks per profiel toe te voegen."
          }
        },
        "pl" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Nie masz jeszcze żadnych zapisanych profili. Stwórz profil w karcie Profile, aby móc przypisywać do nich hooki."
          }
        },
        "pt-BR" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Ainda não há perfis salvos. Crie um na guia “Perfis” para associar ganchos específicos a cada perfil."
          }
        },
        "ru" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Профили еще не созданы. Создайте профиль на вкладке «Профили», чтобы привязать к нему хуки."
          }
        },
        "th" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "ยังไม่มี Profiles ที่บันทึกไว้ สร้าง Profiles ในแท็บ Profiles เพื่อผูก Hooks สำหรับแต่ละ Profiles"
          }
        },
        "tr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Henüz kaydedilmiş bir profil yok. Profile özel hooklar eklemek için Profiller sekmesinden bir profil oluşturun."
          }
        },
        "uk" : {
          "stringUnit" : {

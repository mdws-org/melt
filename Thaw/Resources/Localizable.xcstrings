        "hu" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Elrendezés visszaállítva. Az elemek a Rejtett szakaszba kerültek."
          }
        },
        "id" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Tata Letak diatur ulang. Item dipindahkan ke Bagian Tersembunyi."
          }

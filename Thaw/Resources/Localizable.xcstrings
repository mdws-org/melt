    "%@ can work in a limited mode without this permission." : {
      "comment" : "A callout box that explains that the app can work in a limited mode without a particular permission.",
      "localizations" : {
        "cs" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Bez tohoto oprávnění dokáže %@ pracovat v omezeném režimu."
          }
        },
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "%@ funktioniert nur eingeschränkt ohne diese Erlaubnis."
          }
        },
        "es" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "%@ puede funcionar en modo limitado sin este permiso."
          }
        },
        "fr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Sans ces autorisations, %@ fonctionnera en mode restreint."
          }
        },
        "hu" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "%@ korlátozott módban is működhet ezen engedély nélkül."
          }
        },
        "id" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "%@ dapat berjalan dalam mode terbatas tanpa izin ini."
          }
        },
        "it" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "%@ può funzionare in modalità limitata senza questa autorizzazione."
          }
        },
        "ja" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "%@ はこの権限なしでも制限モードで動作できます。"
          }
        },
        "ko" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "%@은(는) 이 권한 없이도 제한된 모드로 작동할 수 있습니다."
          }
        },
        "nl" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "%@ kan zonder deze toestemming in een beperkte modus werken."
          }
        },
        "pl" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "%@ może działać w ograniczonym zakresie bez tego uprawnienia."
          }
        },
        "pt-BR" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "%@ pode funcionar de modo limitado sem essa permissão."
          }
        },
        "ru" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "%@ может работать в ограниченном режиме без этого разрешения."
          }
        },
        "th" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "%@ สามารถทำงานได้อย่างจำกัด โดยไม่ต้องมีสิทธิ์นี้"
          }
        },
        "tr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "%@ bu izin olmadan sınırlı modda çalışabilir."
          }
        },
        "uk" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "%@ може працювати в обмеженому режимі без цього дозволу."
          }
        },
        "vi" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "%@ có thể hoạt động ở chế độ giới hạn mà không có quyền này."
          }
        },
        "zh-Hans" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "%@ 可以在没有此权限的情况下以受限模式运行。"
          }
        },
        "zh-Hant" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "%@ 可以在沒有此權限的情況下以有限模式運作。"
          }
        }
      }
    },
    "%@ cannot arrange menu bar items in automatically hidden menu bars." : {
      "comment" : "A view that shows a message when the menu bar layout can't be arranged in automatically hidden menu bars.",
      "localizations" : {
        "cs" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "%@ nemůže uspořádat položky v automaticky skrývaných řádcích nabídek."
          }
        },
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "%@ kann Menüleisten-Einträge in automatisch versteckten Menüs nicht anordnen."
          }
        },
        "es" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "%@ no puede organizar los elementos de la barra de menús en barras ocultas automáticamente."
          }
        },
        "fr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "%@ ne peut pas réorganiser les éléments de la barre des menus lorsque celle-ci est masquée automatiquement."
          }
        },
        "hu" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "%@ nem tudja rendezni a menüsor elemeit az automatikusan elrejtett menüsorokban."
          }
        },
        "id" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "%@ tidak dapat menyusun item di bar menu tersembunyi secara otomatis."
          }
        },
        "it" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "%@ non può disporre le voci della barra dei menu nelle barre dei menu nascoste automaticamente."
          }
        },
        "ja" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "%@ は自動的に非表示になるメニューバーではメニューバー項目を整理できません。"
          }
        },
        "ko" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "%@은(는) 자동으로 숨겨진 메뉴 막대에서 항목을 정렬할 수 없습니다."
          }
        },
        "nl" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "%@ kan geen menubalkitems rangschikken in automatisch verborgen menubalken."
          }
        },
        "pl" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "%@ nie może zmienić układu elementów na pasku menu, gdy jest on automatycznie ukrywany."
          }
        },
        "pt-BR" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "%@ não pode organizar itens da barra de menus quando ela está configurada para ocultação automática."
          }
        },
        "ru" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "%@ не может упорядочивать элементы в автоматически скрываемых строках меню."
          }
        },
        "th" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "%@ ไม่สามารถจัดเรียงรายการเมนูในแถบเมนูบาร์ที่ซ่อนโดยอัตโนมัติได้"
          }
        },
        "tr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "%@ otomatik gizlenen menü çubuklarında öğeleri düzenleyemez."
          }
        },
        "uk" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "%@ не може впорядковувати об'єкти в автоматично прихованих рядках меню."
          }
        },
        "vi" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "%@ không thể sắp xếp các mục thanh menu trong các thanh menu ẩn tự động."
          }
        },
        "zh-Hans" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "%@ 无法在自动隐藏菜单栏中排列项目。"
          }
        },
        "zh-Hant" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "%@ 無法在自動隱藏的選單列中排列項目。"
          }
        }
      }
    },
    "%@ cannot edit the appearance of automatically hidden menu bars." : {
      "comment" : "A view that appears when the user tries to edit the appearance of a menu bar that the system has hidden automatically.",
      "localizations" : {
        "cs" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "%@ nemůže spravovat vzhled  automaticky skrývaných řádků nabídek."
          }
        },
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "%@ kann die Darstellung von automatisch versteckten Menüleisten nicht anpassen."
          }
        },
        "es" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "%@ no puede editar la apariencia de las barras ocultas automáticamente."
          }
        },
        "fr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "%@ ne peut pas modifier l'apparence de la barre des menus lorsqu'elle est masquée automatiquement."
          }
        },
        "hu" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "%@ nem tudja szerkeszteni az automatikusan elrejtett menüsorok megjelenését."
          }
        },
        "id" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "%@ tidak dapat mengedit tampilan menu bar tersembunyi secara otomatis."
          }
        },
        "it" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "%@ non può modificare l'aspetto delle barre dei menu nascoste automaticamente."
          }
        },
        "ja" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "%@ は自動的に非表示になるメニューバーの外観を編集できません。"
          }
        },
        "ko" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "%@은(는) 자동으로 숨겨진 메뉴 막대의 모양을 편집할 수 없습니다."
          }
        },
        "nl" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "%@ kan het uiterlijk van automatisch verborgen menubalken niet bewerken"
          }
        },
        "pl" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "%@ nie może edytować wyglądu automatycznie ukrywanych pasków menu."
          }
        },
        "pt-BR" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "%@ não pode editar a aparência da barra de menus quando ela está configurada para ocultação automática."
          }
        },
        "ru" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "%@ не может изменять внешний вид автоматически скрываемых строк меню."
          }
        },
        "th" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "%@ ไม่สามารถแก้ไขลักษณะของแถบเมนูที่ซ่อนโดยอัตโนมัติได้"
          }
        },
        "tr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "%@ otomatik gizlenen menü çubuklarının görünümünü düzenleyemez."
          }
        },
        "uk" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "%@ не може редагувати вигляд автоматично прихованих рядків меню."
          }
        },
        "vi" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "%@ không thể chỉnh sửa hình thức của thanh menu ẩn tự động."
          }
        },
        "zh-Hans" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "%@ 无法修改自动隐藏菜单栏的外观。"
          }
        },
        "zh-Hant" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "%@ 無法編輯自動隱藏選單列的外觀。"
          }
        }
      }
    },

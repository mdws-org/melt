    "The %@ Bar is aligned to the left edge of the display." : {
      "comment" : "A label that describes the location of the \\(Constants.displayName) Bar on a display.",
      "localizations" : {
        "cs" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Lišta %@ je zarovnaná k levému okraji monitoru."
          }
        },
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Die %@-Leiste ist am linken Rand des Bildschirms ausgerichtet."
          }
        },
        "es" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "La barra %@ está alineada con el borde izquierdo de la pantalla."
          }
        },
        "fr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "La %@ Bar est alignée sur le bord gauche de l'écran."
          }
        },
        "hu" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "A %@ sáv a kijelző bal széléhez van igazítva."
          }
        },
        "id" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Bar %@ disejajarkan ke tepi kiri layar."
          }
        },
        "it" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "La Barra %@ è allineata nel lato sinistro dello schermo."
          }
        },
        "ja" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "%@ バーは画面の左端に配置されています。"
          }
        },
        "ko" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "%@ 막대는 디스플레이의 왼쪽 가장자리에 정렬되어 있습니다."
          }
        },
        "nl" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "De %@-balk is uitgelijnd aan de linkerrand van het scherm."
          }
        },
        "pl" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Pasek %@ jest wyrównany do lewej krawędzi wyświetlacza."
          }
        },
        "pt-BR" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "A Barra %@ está alinhada à margem esquerda da tela."
          }
        },
        "ru" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Панель %@ выровнена по левому краю экрана."
          }
        },
        "th" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "แถบ %@ จะอยู่ชิดขอบด้านซ้ายของหน้าจอแสดงผล"
          }
        },
        "tr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "%@ Çubuğu ekranın sol kenarına hizalanmıştır."
          }
        },
        "uk" : {
          "stringUnit" : {
            "state" : "new",
            "value" : "The %@ Bar is aligned to the left edge of the display."
          }
        },
        "vi" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Thanh %@ được căn chỉnh về cạnh trái của màn hình."

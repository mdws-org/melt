    "Apps that request settings access will appear here after you approve them." : {
      "comment" : "A description of the whitelisted apps section.",
      "localizations" : {
        "cs" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Aplikace s přístupem k nastavení se zobrazí zde, když je schválíte."
          }
        },
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Anwendungen die Zugriff auf die Einstellungen anfragen, erscheinen hier nach dem Zulassen."
          }
        },
        "es" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Las aplicaciones que soliciten acceso a la configuración aparecerán aquí después de aprobarlas."
          }
        },
        "fr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Les applications qui demandent un accès aux paramètres apparaîtront ici une fois approuvées."
          }
        },
        "hu" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "A beállításokhoz hozzáférést kérő alkalmazások itt jelennek meg, miután jóváhagytad őket."
          }
        },
        "id" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Aplikasi yang meminta akses pengaturan akan ditampilakn di sini setelah disetujui."
          }
        },
        "it" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Le applicazioni che richiedono l'accesso alle impostazioni appariranno qui dopo l'approvazione."
          }
        },
        "ja" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "設定へのアクセスをリクエストしたアプリは、承認後にここに表示されます。"
          }
        },
        "ko" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "설정 접근을 요청하는 앱을 승인하면 이곳에 표시됩니다."
          }
        },
        "nl" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Apps die toegang tot instellingen vragen, worden hier weergegeven nadat je ze hebt goedgekeurd."
          }
        },
        "pl" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Aplikacje, które żądają dostępu do ustawień, pojawią się tutaj po ich zatwierdzeniu."
          }
        },
        "pt-BR" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Os aplicativos que solicitam acesso às configurações aparecerão aqui depois que você os aprovar."
          }
        },
        "ru" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Приложения, запрашивающие доступ к настройкам, появятся здесь после их утверждения."
          }
        },
        "th" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "แอปที่ขอสิทธิ์การเข้าถึงการตั้งค่าจะปรากฏที่นี่หลังจากที่คุณอนุมัติ"
          }
        },
        "tr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Ayar erişimi talep eden uygulamalar onayladıktan sonra burada görünecektir."
          }
        },
        "uk" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Додатки, які мають доступ до налаштувань будуть з'являтися тут після того, як ви їх затвердите."
          }
        },
        "vi" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Các ứng dụng yêu cầu quyền truy cập cài đặt sẽ xuất hiện ở đây sau khi bạn phê duyệt chúng."
          }
        },
        "zh-Hans" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "已获批准访问设置的应用将显示在此处。"
          }
        },
        "zh-Hant" : {
          "stringUnit" : {

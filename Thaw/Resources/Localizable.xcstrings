            "state" : "translated",
            "value" : "允許「%1$@」控制 %2$@ 的設定嗎？"
          }
        }
      }
    },
    "Allow external applications to read and modify %@ settings via thaw:// URLs." : {
      "comment" : "A toggle that enables or disables the ability for external applications to read and modify \\(Constants.displayName) settings via thaw:// URLs.",
      "localizations" : {
        "cs" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Povolit jiným aplikacím, aby četly a měnily nastavení %@ pomocí URL thaw://."
          }
        },
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Externen Anwendungen erlauben %@ -Einstellungen über thaw:// URLs zu lesen und zu ändern."
          }
        },
        "es" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Permitir a las aplicaciones externas leer y modificar la configuración de %@ a través de thaw:// URLs."
          }
        },
        "fr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Autoriser les applications externes à lire et à modifier les paramètres %@ via des URL thaw://."
          }
        },
        "hu" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Külső alkalmazások engedélyezése %@ beállításainak olvasására és módosítására thaw:// URL-eken keresztül."
          }
        },
        "id" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Izinkan aplikasi eksternal untuk membaca dan mengubah pengaturan %@ via thaw://URL."
          }
        },
        "it" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Permetti ad applicazioni esterne di leggere e modificare le impostazioni di %@ tramite thaw://URLs."
          }
        },
        "ja" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "外部のアプリが thaw::// URLを通じて %@の設定を読み書きできるようにします。"
          }
        },
        "ko" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "외부 애플리케이션이 thaw:// URL을 통해 %@ 설정을 읽고 수정할 수 있도록 허용합니다."
          }
        },
        "nl" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Sta externe applicaties toe om %@-instellingen te lezen en te wijzigen via thaw://-URL’s."
          }
        },
        "pl" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Zezwalaj zewnętrznym aplikacjom na odczyt i modyfikację ustawień %@ za pomocą adresów URL thaw://."
          }
        },
        "pt-BR" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Permitir que aplicativos externos leiam e modifiquem as configurações %@ por meio de URLs thaw://."
          }
        },
        "ru" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Разрешить внешним приложениям считывать и изменять настройки %@ через thaw:// URL-адреса."
          }
        },
        "th" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "อนุญาตให้แอปภายนอกอ่านและแก้ไขการตั้งค่า %@ ผ่าน URL แบบ thaw://"
          }
        },
        "tr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Dış uygulamaların %@ ayarlarını thaw:// bağlantısı aracılığıyla okumasına ve düzenlemesine izin ver."
          }
        },
        "uk" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Дозволити зовнішнім застосункам читати та змінювати налаштування %@ через URL-адреси thaw://."
          }
        },
        "vi" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Cho phép các ứng dụng bên ngoài đọc và sửa đổi cài đặt %@ thông qua URL thaw://."
          }
        },
        "zh-Hans" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "允许外部应用程序通过 thaw:// URL 读取并修改 %@ 设置。"
          }
        },
        "zh-Hant" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "允許外部應用程式透過 thaw:// URL 讀取並修改 %@ 的設定。"
          }
        }
      }
    },
    "Always show hidden items" : {
      "comment" : "A toggle that allows users to configure whether hidden menu bar items should always be visible in the native menu bar on a particular display.",
      "localizations" : {
        "cs" : {
          "stringUnit" : {

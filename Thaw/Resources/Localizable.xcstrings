    "Tip: You can also edit these settings by right-clicking in an empty area of the menu bar." : {
      "comment" : "Tip text that appears in the menu bar appearance editor, encouraging users to edit the settings by right-clicking in an empty area of the menu bar.",
      "localizations" : {
        "cs" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Tip: Tato nastavení můžete upravit také tak, že kliknete pravým tlačítkem myši na prázdné místo na řádku nabídek."
          }
        },
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Tipp: Diese Einstellungen können auch durch einen Rechtsklick in einen leeren Bereich der Menüleiste angepasst werden."

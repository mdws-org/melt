    "Click an empty area of the menu bar to show hidden menu bar items." : {
      "comment" : "Toggle that allows the user to enable or disable the feature of showing hidden menu bar items by clicking on an empty area of the menu bar.",
      "localizations" : {
        "cs" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Klikněte na prázdnou část řádku nabídek, aby se zobrazily skryté položky."
          }
        },
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Einen leeren Bereich der Menüleiste anklicken, um versteckte Menüleisten-Einträge anzuzeigen."
          }
        },
        "es" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Haz clic en un área vacía de la barra de menús para mostrar los elementos ocultos."
          }
        },
        "fr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Cliquez dans un espace vide de la barre des menus pour afficher les éléments masqués."
          }
        },
        "hu" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Kattints a menüsáv egy üres területére a rejtett menüsávelemek megjelenítéséhez."
          }
        },
        "id" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Klik area kosong bar menu untuk menampilkan item bar menu tersembunyi."
          }
        },
        "it" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Fare clic su un'area vuota della barra dei menu per visualizzare gli elementi nascosti della barra dei menu."
          }
        },
        "ja" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "メニューバーの空いている領域をクリックすると、非表示のメニューバー項目が表示されます。"
          }
        },
        "ko" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "메뉴 막대의 빈 공간을 클릭하면 숨겨진 메뉴 막대 항목이 표시됩니다."
          }
        },
        "nl" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Klik op een leeg gedeelte van de menubalk om verborgen menu-items weer te geven."
          }
        },
        "pl" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Kliknij pusty obszar paska menu, aby wyświetlić ukryte elementy paska menu."
          }
        },
        "pt-BR" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Clique em uma área vazia da barra de menus para mostrar os itens ocultos da barra de menus."
          }
        },
        "ru" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Нажмите на пустую область строки меню, чтобы показать скрытые элементы."
          }
        },
        "th" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "คลิกบริเวณว่างของแถบเมนูเพื่อแสดงรายการแถบเมนูที่ซ่อนไว้"

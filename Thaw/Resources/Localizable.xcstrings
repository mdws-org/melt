    "Scroll or swipe in the menu bar to show hidden menu bar items." : {
      "comment" : "Label for a toggle that enables or disables showing hidden menu bar items when scrolling or swiping in the menu bar.",
      "localizations" : {
        "cs" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Rolujte nebo přejeďte kurzorem po řádku nabídek, aby se zobrazily skryté položky."
          }
        },
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Scrollen oder Wischen um versteckte Menüleisten-Einträge anzuzeigen."
          }
        },
        "es" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Desplázate o desliza sobre la barra de menús para mostrar los elementos ocultos."
          }
        },
        "fr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Faites défiler ou balayez la souris dans la barre des menus pour afficher les éléments masqués."
          }
        },
        "hu" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Görgessen vagy húzzon a menüsorban a rejtett menüsor elemek megjelenítéséhez."
          }
        },
        "id" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Gulir atau usap di bar menu untuk tampilkan item bar menu tersembunyi."
          }
        },
        "it" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Scorrere o scorrere la barra dei menu per visualizzare gli elementi nascosti della barra dei menu."
          }
        },
        "ja" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "メニューバーでスクロールまたはスワイプすると、非表示のメニューバー項目が表示されます。"
          }
        },
        "ko" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "메뉴 막대에서 스크롤하거나 스와이프하여 숨겨진 메뉴 막대 항목을 표시합니다."
          }
        },
        "nl" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Scroll of veeg in de menubalk om verborgen menu-items weer te geven."
          }
        },
        "pl" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Użyj gestu przewijania lub przesunięcia na pasku menu, aby odsłonić ukryte opcje."
          }
        },
        "pt-BR" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Role ou deslize na barra de menus para mostrar os itens ocultos da barra de menus."
          }
        },
        "ru" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Прокрутите или проведите по строке меню, чтобы показать скрытые элементы."
          }
        },
        "th" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "เลื่อนหรือปัดบนแถบเมนูเพื่อแสดงรายการที่ซ่อนอยู่"
          }
        },
        "tr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Gizli menü çubuğu öğelerini göstermek için menü çubuğunda kaydırın veya parmağınızı sürükleyin."
          }
        },
        "uk" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Прокручуйте або проводьте пальцем у рядку меню, щоб показати приховані об'єкти."
          }
        },
        "vi" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Cuộn hoặc vuốt trong thanh menu để hiển thị các mục thanh menu ẩn."
          }
        },
        "zh-Hans" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "在菜单栏中滚动或滑动即可显示隐藏的菜单栏项目。"

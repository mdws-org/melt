    "Reset completed with %lld item(s) that could not be moved. Check the menu bar and try again if needed." : {
      "comment" : "A message describing the result of a menu bar layout reset, including the number of items that could not be moved.",
      "localizations" : {
        "cs" : {
          "stringUnit" : {

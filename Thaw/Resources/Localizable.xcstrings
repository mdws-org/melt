    "Not available because the %@ Bar is enabled for this display." : {
      "comment" : "A message explaining that the \"Always show hidden items\" toggle is not available when the \"Use \\(Constants.displayName) Bar\" toggle is enabled.",
      "localizations" : {
        "cs" : {
          "stringUnit" : {

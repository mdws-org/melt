    "Allow \"%@\" to control %@ settings?" : {
      "comment" : "Title of the NSAlert confirmation dialog for first-time authorization.",
      "localizations" : {
        "cs" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Povolit aplikaci „%1$@“, aby měnila nastavení %2$@?"
          }
        },
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "\"%1$@\" erlauben, %2$@ Einstellungen zu kontrollieren?"
          }
        },
        "en" : {
          "stringUnit" : {
            "state" : "new",
            "value" : "Allow \"%1$@\" to control %2$@ settings?"
          }
        },
        "es" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "¿Permitir que \"%1$@\" controle los ajustes de %2$@?"
          }
        },
        "fr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Autoriser \"%1$@\" à gérer les paramètres de %2$@?"
          }
        },
        "hu" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Engedélyezi, hogy \"%1$@\" vezérelje %2$@ beállításait?"
          }
        },
        "id" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Izinkan \"%1$@\" untuk mengendalikan pengaturan %2$@?"
          }
        },
        "it" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Permetti a \"%1$@\" di controllare le impostazioni di %2$@?"
          }
        },
        "ja" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "「%1$@」が「%2$@」の設定を制御することを許可しますか？"
          }
        },
        "ko" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "\"%1$@\"(이)가 %2$@ 설정을 제어하도록 허용하시겠습니까?"
          }
        },
        "nl" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Mag “%1$@” de instellingen van %2$@ beheren?"
          }
        },
        "pl" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Pozwolić „%1$@” kontrolować ustawienia %2$@ ?"
          }
        },
        "pt-BR" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Permitir que “%1$@” controle as configurações de %2$@?"
          }
        },
        "ru" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Разрешить \"%1$@\" для управления настройками %2$@?"
          }
        },
        "th" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "อนุญาตให้ \"%1$@\" ควบคุมการตั้งค่า %2$@ หรือไม่?"
          }
        },
        "tr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "%1$@ uygulamasının %2$@ ayarlarını kontrol etmesine izin verilsin mi?"
          }
        },
        "uk" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Дозволити \"%1$@\" керувати налаштуваннями %2$@?"
          }
        },
        "vi" : {
          "stringUnit" : {
            "state" : "translated",
